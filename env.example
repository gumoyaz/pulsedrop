# ── Database ────────────────────────────────────────────────────
# Path to the local SQLite file (used by Prisma CLI only;
# the runtime client resolves the path from process.cwd()).
DATABASE_URL="file:./dev.db"

# ── Google Analytics 4 ──────────────────────────────────────────
# Your GA4 numeric property ID (digits only, no "properties/" prefix).
# Find it in GA4 → Admin → Property Settings → Property ID.
GA4_PROPERTY_ID="YOUR_NUMERIC_PROPERTY_ID"

# The full contents of your Google Cloud service account JSON key,
# pasted as a single-line string (use `jq -c . key.json` to compact it).
# Keep this secret — never commit the real value.
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\\n","client_email":"pulsedrop@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
